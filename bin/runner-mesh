#!/usr/bin/env bash
# runner-mesh — bootstrap and operate a fleet of ephemeral, autoscaling
# GitHub Actions runners (via Actions Runner Controller) on your own
# Kubernetes cluster.
set -euo pipefail

rm::resolve_root() {
  local src="${BASH_SOURCE[0]}"
  while [[ -L "${src}" ]]; do
    local dir
    dir="$(cd -P "$(dirname "${src}")" && pwd)"
    src="$(readlink "${src}")"
    [[ "${src}" != /* ]] && src="${dir}/${src}"
  done
  cd -P "$(dirname "${src}")/.." && pwd
}

RM_ROOT="$(rm::resolve_root)"
readonly RM_ROOT
export RM_ROOT

# Each lib is sourced if present, so the CLI stays runnable while a command's
# implementation lands in its own commit.
for _rm_lib in log preflight cluster github_app net repos status node fleet gitops migrate; do
  if [[ -f "${RM_ROOT}/lib/${_rm_lib}.sh" ]]; then
    # shellcheck source=/dev/null
    source "${RM_ROOT}/lib/${_rm_lib}.sh"
  fi
done
unset _rm_lib

rm::usage() {
  cat <<'EOF'
runner-mesh — self-hosted GitHub Actions runners on your own Kubernetes cluster

USAGE
  runner-mesh <command> [flags]

COMMANDS
  doctor              Verify local toolchain and cluster connectivity

  net:init              One guided browser setup for Tailscale (account,
                        tag ACL, OAuth client) — after it, auth keys mint
                        from the terminal and node:* needs no --authkey
  net:key                Mint a tagged single-use Tailscale auth key
  net:ip                 Reassign a tailnet device's 100.x IP (API) — used to
                        take over a control-plane IP hands-off on recovery

  node:init             Print the plan to bootstrap this machine as the
                        first k3s cluster node (Tailscale-meshed)
  node:join             Print the plan to join an existing cluster
  node:auto              Read-only discovery + print init or join plan,
                        whichever this machine needs (same 2 secrets
                        on every machine)
  node:promote           Print the plan to recover a dead control plane onto
                        a surviving node: restore the latest etcd snapshot
                        and take over the old server's tailnet IP (fast
                        recovery in minutes, not seamless failover)
  node:watchdog          Print the plan to install a control-plane watchdog on
                        a standby: watch the primary, alert (or --auto-promote
                        via node:promote) on sustained loss

  cluster:install      Install/upgrade the Actions Runner Controller
  cluster:uninstall    Remove the controller (repos must be removed first)
  app:init              Create a GitHub App via the manifest flow and store its
                        credentials as a cluster Secret
  repos:list             List repos visible to the GitHub App and their status
  repos:add <repo>       Provision a runner scale-set for owner/repo
  repos:remove <repo>    Tear down the runner scale-set for owner/repo
  repos:audit [path]     Scan a checkout's workflows: which runs-on targets
                        actually reach a provisioned scale-set (name-only
                        matching — label arrays never do)
  repos:migrate <path>   Rewrite runs-on targets per an explicit
                        --map 'labels=name' mapping; --pr opens a draft PR
  status                Show controller + per-repo runner pool health

  fleet:init [dir]       Scaffold a data-only fleet config repo (repos.txt,
                        engine pin, values/, delegating shim)
  fleet:apply [dir]      Converge the cluster on a config repo's declared
                        state; --prune also removes unlisted scale-sets
  fleet:seal [dir]       Encrypt the GitHub App credentials into the fleet
                        repo (SOPS+age); apply auto-unseals on machines
                        holding the fleet age key
  fleet:gitops [dir]     Generate a Flux CD layout in the fleet repo so the
                        cluster reconciles itself from git (docs/gitops-flux.md)
  version               Print the runner-mesh version

node:* commands never touch root/systemd themselves — they print the
exact install commands (or do read-only Tailscale discovery) for you to
review and run. cluster:*/repos:* commands do act directly, but only via
your own existing kubectl credentials against a cluster you already
control — no new installers, no new privilege.

GLOBAL FLAGS
  --yes, -y           Assume "yes" to confirmation prompts (non-interactive)
  --dry-run           Print planned actions without applying them

Run 'runner-mesh <command> --help' for command-specific flags.
EOF
}

main() {
  # Global flags can appear anywhere, including before the command
  # (e.g. 'runner-mesh --yes cluster:uninstall'), so scan the full
  # argument list first and only then take the first non-flag token as
  # the command.
  local args=() a
  for a in "$@"; do
    case "${a}" in
      --yes|-y) export RM_YES=1 ;;
      --dry-run) export RM_DRY_RUN=1 ;;
      *) args+=("${a}") ;;
    esac
  done

  local cmd="${args[0]:-}"
  if [[ ${#args[@]} -gt 0 ]]; then
    args=("${args[@]:1}")
  fi
  set -- "${args[@]+"${args[@]}"}"

  case "${cmd}" in
    doctor)            rm::preflight::run ;;
    node:init)          rm::node::init "$@" ;;
    node:join)          rm::node::join "$@" ;;
    node:auto)           rm::node::auto "$@" ;;
    node:promote)        rm::node::promote "$@" ;;
    node:watchdog)       rm::node::watchdog "$@" ;;
    cluster:install)   rm::cluster::install "$@" ;;
    cluster:uninstall) rm::cluster::uninstall "$@" ;;
    app:init)           rm::github_app::init "$@" ;;
    repos:list)          rm::repos::list "$@" ;;
    repos:add)           rm::repos::add "$@" ;;
    repos:remove)        rm::repos::remove "$@" ;;
    repos:audit)         rm::repos::audit "$@" ;;
    repos:migrate)       rm::migrate::run "$@" ;;
    status)             rm::status::run "$@" ;;
    fleet:init)          rm::fleet::init "$@" ;;
    fleet:apply)         rm::fleet::apply "$@" ;;
    fleet:seal)          rm::fleet::seal "$@" ;;
    fleet:gitops)        rm::gitops::scaffold "$@" ;;
    net:init)            rm::net::init "$@" ;;
    net:key)             rm::net::key "$@" ;;
    net:ip)              rm::net::ip "$@" ;;
    version)            printf 'runner-mesh %s\n' "$(cat "${RM_ROOT}/VERSION" 2>/dev/null || echo dev)" ;;
    -h|--help|help|"")  rm::usage ;;
    *)
      rm::warn "unknown command: ${cmd}"
      rm::usage
      exit 1
      ;;
  esac
}

main "$@"
